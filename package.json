{
  "name": "bellsy",
  "displayName": "Bellsy",
  "description": "Notifications for local coding agents, scripts, and CLI tools when work finishes, fails, or needs approval.",
  "version": "0.2.0",
  "publisher": "rkhooda07",
  "license": "MIT",
  "preview": false,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Utilities",
    "Other"
  ],
  "keywords": [
    "notifications",
    "agent",
    "productivity",
    "codex",
    "claude-code",
    "vscode",
    "local"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:bellsy.showLogs",
    "onCommand:bellsy.setupLocalNotifications",
    "onCommand:bellsy.testLocalNotifications",
    "onCommand:bellsy.toggleSoundMode"
  ],
  "main": "./out/extension.js",
  "bin": {
    "bellsy-run": "./out/cli/pingly-run.js"
  },
  "icon": "assets/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "bellsy.showLogs",
        "title": "Bellsy: Show Logs"
      },
      {
        "command": "bellsy.setupLocalNotifications",
        "title": "Bellsy: Setup Local Agent Notifications"
      },
      {
        "command": "bellsy.testLocalNotifications",
        "title": "Bellsy: Test Local Notifications"
      },
      {
        "command": "bellsy.toggleSoundMode",
        "title": "Bellsy: Toggle Sound Mode"
      }
    ],
    "configuration": {
      "title": "Bellsy",
      "properties": {
        "bellsy.httpPort": {
          "type": "number",
          "default": 9001,
          "minimum": 1,
          "maximum": 65535,
          "description": "Preferred loopback HTTP port used by the extension. If the port is busy, Bellsy automatically falls back to another free local port."
        },
        "bellsy.soundEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable bundled notification sounds."
        },
        "bellsy.soundVolume": {
          "type": "number",
          "default": 45,
          "minimum": 0,
          "maximum": 100,
          "description": "Preferred playback volume. Applied to macOS native playback and supported bundled playback commands."
        },
        "bellsy.soundMode": {
          "type": "string",
          "default": "focus",
          "enum": [
            "focus",
            "vibe"
          ],
          "description": "Controls sound style: focus (professional) or vibe (fun)."
        },
        "bellsy.httpResponseTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 1000,
          "description": "How long the HTTP transport waits for an allow or deny response."
        },
        "bellsy.permissionReminderEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show repeated in-editor reminders while permission requests remain unanswered."
        },
        "bellsy.permissionReminderIntervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "How often to repeat the pending permission reminder."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "pretest": "npm run build",
    "test": "node --test test/unit/*.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "package:verify": "npm test && npm run package"
  },
  "dependencies": {
    "node-notifier": "^10.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/node-notifier": "^8.0.5",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.5"
  }
}
