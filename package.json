{
  "name": "bellsy",
  "displayName": "Bellsy",
  "description": "Notifications for local coding agents, scripts, and CLI tools when work finishes, fails, or needs approval.",
  "version": "0.2.0",
  "publisher": "rkhooda07",
  "license": "MIT",
  "preview": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/Rkhooda07/Bellsy.git"
  },
  "homepage": "https://github.com/Rkhooda07/Bellsy#readme",
  "bugs": {
    "url": "https://github.com/Rkhooda07/Bellsy/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "extensionKind": [
    "ui"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": true
  },
  "categories": [
    "Utilities",
    "Other"
  ],
  "galleryBanner": {
    "color": "#0D2930",
    "theme": "dark"
  },
  "keywords": [
    "notifications",
    "agent",
    "productivity",
    "codex",
    "claude-code",
    "cursor",
    "vscode",
    "local"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:bellsy.showLogs",
    "onCommand:bellsy.setupLocalNotifications",
    "onCommand:bellsy.testLocalNotifications",
    "onCommand:bellsy.toggleSoundMode"
  ],
  "main": "./out/extension.js",
  "bin": {
    "bellsy-run": "out/cli/bellsy-run.js"
  },
  "files": [
    "out",
    "sounds",
    "assets/icon.png"
  ],
  "icon": "assets/MaybeFinalLogo.png",
  "contributes": {
    "commands": [
      {
        "command": "bellsy.showLogs",
        "title": "Bellsy: Show Logs"
      },
      {
        "command": "bellsy.setupLocalNotifications",
        "title": "Bellsy: Setup Local Agent Notifications"
      },
      {
        "command": "bellsy.testLocalNotifications",
        "title": "Bellsy: Test Local Notifications"
      },
      {
        "command": "bellsy.toggleSoundMode",
        "title": "Bellsy: Toggle Sound Mode"
      }
    ],
    "configuration": {
      "title": "Bellsy",
      "properties": {
        "bellsy.httpPort": {
          "type": "number",
          "default": 9001,
          "minimum": 1,
          "maximum": 65535,
          "description": "Preferred loopback HTTP port used by the extension. If the port is busy, Bellsy automatically falls back to another free local port."
        },
        "bellsy.soundEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable bundled notification sounds."
        },
        "bellsy.soundVolume": {
          "type": "number",
          "default": 45,
          "minimum": 0,
          "maximum": 100,
          "description": "Preferred playback volume. Applied to macOS native playback and supported bundled playback commands."
        },
        "bellsy.soundMode": {
          "type": "string",
          "default": "focus",
          "enum": [
            "focus",
            "vibe"
          ],
          "description": "Controls sound style: focus (professional) or vibe (fun)."
        },
        "bellsy.httpResponseTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 1000,
          "description": "How long the HTTP transport waits for an allow or deny response."
        },
        "bellsy.permissionReminderEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show repeated in-editor reminders while permission requests remain unanswered."
        },
        "bellsy.permissionReminderIntervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "How often to repeat the pending permission reminder."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "bundle": "node tools/bundle.js",
    "build": "npm run compile && npm run bundle",
    "vscode:prepublish": "npm run build",
    "pretest": "npm run build",
    "test": "node --test test/unit/*.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "package:verify": "npm test && npm run package"
  },
  "vsce": {
    "baseImagesUrl": "https://raw.githubusercontent.com/Rkhooda07/Bellsy/02b320c"
  },
  "dependencies": {
    "node-notifier": "^10.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/node-notifier": "^8.0.5",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.5"
  }
}
