{
  "name": "ai-agent-notifier",
  "displayName": "AI Agent Notifier",
  "description": "Local notifications for coding agents when they need approval or finish work.",
  "version": "0.2.0",
  "publisher": "rkhooda07",
  "license": "MIT",
  "preview": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Utilities",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "notifications",
    "codex",
    "claude-code",
    "cursor",
    "permissions",
    "productivity"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Rkhooda07/Pingly.git"
  },
  "homepage": "https://github.com/Rkhooda07/Pingly#readme",
  "bugs": {
    "url": "https://github.com/Rkhooda07/Pingly/issues"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:agentNotifier.showLogs",
    "onCommand:agentNotifier.simulatePermission",
    "onCommand:agentNotifier.simulateComplete",
    "onCommand:agentNotifier.showPendingList"
  ],
  "main": "./out/extension.js",
  "icon": "assets/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "agentNotifier.showLogs",
        "title": "AI Notifier: Show Logs"
      },
      {
        "command": "agentNotifier.simulatePermission",
        "title": "AI Notifier: Simulate Permission Request"
      },
      {
        "command": "agentNotifier.simulateComplete",
        "title": "AI Notifier: Simulate Task Completed"
      },
      {
        "command": "agentNotifier.showPendingList",
        "title": "AI Notifier: Show Pending Requests"
      }
    ],
    "configuration": {
      "title": "AI Agent Notifier",
      "properties": {
        "agentNotifier.transport": {
          "type": "string",
          "enum": [
            "file",
            "http"
          ],
          "default": "http",
          "description": "Transport used to receive AI agent events."
        },
        "agentNotifier.httpPort": {
          "type": "number",
          "default": 9001,
          "minimum": 1,
          "maximum": 65535,
          "description": "Loopback HTTP port used by the extension."
        },
        "agentNotifier.watchFilePath": {
          "type": "string",
          "default": "/tmp/agent_event.json",
          "description": "Path to the JSON file watched in file transport mode."
        },
        "agentNotifier.watchResponseFilePath": {
          "type": "string",
          "default": "/tmp/agent_response.json",
          "description": "Path written with allow or deny responses in file transport mode."
        },
        "agentNotifier.soundEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable notification sounds."
        },
        "agentNotifier.soundVolume": {
          "type": "number",
          "default": 45,
          "minimum": 0,
          "maximum": 100,
          "description": "Preferred playback volume. Applied on supported platforms."
        },
        "agentNotifier.httpResponseTimeoutMs": {
          "type": "number",
          "default": 300000,
          "minimum": 1000,
          "description": "How long the HTTP transport waits for an allow or deny response."
        },
        "agentNotifier.permissionReminderEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Show repeated in-editor reminders while permission requests remain unanswered."
        },
        "agentNotifier.permissionReminderIntervalSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "description": "How often to repeat the pending permission reminder."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "pretest": "npm run build",
    "test": "node --test test/unit/*.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies",
    "package:verify": "npm test && npm run package"
  },
  "dependencies": {
    "node-notifier": "^10.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/node-notifier": "^8.0.5",
    "@types/uuid": "^10.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.5"
  }
}
